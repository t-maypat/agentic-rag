# Backend origin (the client appends /api/... to this). Omit for local dev to
# default to http://localhost:8000.
VITE_API_BASE_URL=https://your-backend-service.onrender.com

# Optional: hCaptcha site key. When set, the composer shows the widget and a
# token is required on every /api/research call (matches REQUIRE_HCAPTCHA in prod).
VITE_HCAPTCHA_SITE_KEY=your-hcaptcha-site-key

# Optional: GitHub link shown in the header.
VITE_GITHUB_URL=https://github.com/your-user/loupe
