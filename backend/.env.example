# Loupe backend configuration. Copy to .env and fill in.

APP_ENV=dev

# Providers
GEMINI_API_KEY=your-gemini-api-key
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=loupe
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
# Optional: enables the Deep-mode web tool (Phase 3).
TAVILY_API_KEY=

# Models
MODEL_SYNTH=gemini-2.5-flash
MODEL_CONTROL=gemini-2.5-flash-lite

# Retrieval
HYBRID_ALPHA=0.6
RETRIEVE_TOP_K=8

# Access / security
CORS_ORIGINS=["http://localhost:5173"]
REQUIRE_HCAPTCHA=false
HCAPTCHA_SECRET_KEY=
# Number of trusted proxy hops for client-IP resolution (Render=1).
TRUSTED_PROXY=0
RATE_LIMIT_REQUESTS_PER_WINDOW=8
RATE_LIMIT_WINDOW_SECONDS=300
DAILY_REQUEST_LIMIT=200
