# Loupe backend configuration. Copy to .env and fill in.

APP_ENV=dev

# Providers
GEMINI_API_KEY=your-gemini-api-key
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=loupe
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
# Optional: enables the Deep-mode web tool (Phase 3).
TAVILY_API_KEY=

# Observability (optional). Set all three to enable Langfuse tracing (§9):
# one trace per request, a span per node, a generation per LLM call. When unset,
# a no-op tracer is used and /api/health reports "tracing": false.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Models
MODEL_SYNTH=gemini-2.5-flash
MODEL_CONTROL=gemini-2.5-flash-lite

# Agent
# HITL approval gate for Deep mode (prod=true; the interrupt itself lands in Phase 3).
REQUIRE_DEEP_APPROVAL=false

# Retrieval
HYBRID_ALPHA=0.6
RETRIEVE_TOP_K=8

# Access / security
# Comma-separated allowed origins (lock to your Vercel domain in prod; never "*").
CORS_ORIGINS=http://localhost:5173
REQUIRE_HCAPTCHA=false
HCAPTCHA_SECRET_KEY=
# Number of trusted proxy hops for client-IP resolution (Render=1).
TRUSTED_PROXY=0
RATE_LIMIT_REQUESTS_PER_WINDOW=8
RATE_LIMIT_WINDOW_SECONDS=300
# Per-IP daily cap.
DAILY_REQUEST_LIMIT=200
# Aggregate daily kill-switch across ALL clients — bounds total API spend under
# distributed abuse. Set well above expected legitimate daily traffic.
GLOBAL_DAILY_REQUEST_LIMIT=2000
